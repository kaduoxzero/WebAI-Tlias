<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kaduox.mapper.EmpExprMapper">
    <!--批量保存员工工作经历信息
    foreach 标签:
        collection: 集合
        item: 集合中的元素
        open: 批量插入数据的开头
        close: 批量插入数据的结尾
        separator: 分割符
    -->
    <insert id="insertBatch">
        insert into emp_expr (emp_id, begin, end, company, job) values
        <foreach collection="empExprList" item="expr" separator=",">
            (#{expr.empId}, #{expr.begin}, #{expr.end}, #{expr.company}, #{expr.job})
        </foreach>
    </insert>

    <delete id="deleteByEmpIds">
        delete from emp_expr where emp_id in
        <foreach collection="empIds" item="empId" open="(" close=")" separator=",">
            #{empId}
        </foreach>
    </delete>

    <select id="list" parameterType="com.kaduox.pojo.Emp" resultType="com.kaduox.pojo.Emp">
        SELECT
        id, emp_name, age, gender, job, entry_date, dept_id, is_deleted
        FROM
        emp
        WHERE
        is_deleted = 0
        <!-- 姓名模糊查询：非空才拼接 -->
        <if test="empName != null and empName != ''">
            AND emp_name LIKE CONCAT('%', #{empName}, '%')
        </if>
        <!-- 性别精确查询：非空才拼接 -->
        <if test="gender != null">
            AND gender = #{gender}
        </if>
        ORDER BY
        entry_date DESC
    </select>

</mapper>

